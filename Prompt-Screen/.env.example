FIGMA_TOKEN=your_figma_personal_access_token
FIGMA_FILE_KEY=your_figma_file_key
# Optional
# FIGMA_OUTPUT_FILE=meta/figma-file.json
# META_DIR=meta
# SKIP_FETCH=1

# ── AI provider (server-side defaults) ──────────────────────────────────────
# The Settings modal in the UI sends per-request provider/model/key that
# override these. These are the fallback used when the modal is empty.
# AI_PROVIDER selects the backend: ollama | anthropic | openai  (default: ollama)
# AI_PROVIDER=ollama

# Ollama (local) — current default
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_ENABLED=true        # set to "false" to disable the local Ollama path

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI / OpenAI-compatible (LM Studio, llama.cpp, ...)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
